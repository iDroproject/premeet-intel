# PreMeet Environment Variables
# Copy to .env and fill in values from your Supabase project dashboard.

# API Base URL — the root URL for PreMeet edge functions
# For Supabase-hosted: https://your-project.supabase.co/functions/v1
# For self-hosted: https://api.your-domain.com
VITE_API_BASE_URL=https://your-project.supabase.co/functions/v1

# Stripe
STRIPE_API_KEY=your-stripe-restricted-key-here
STRIPE_PRO_PRICE_ID=your-pro-price-id-here
STRIPE_ENTERPRISE_PRICE_ID=your-enterprise-price-id-here
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret-here

# Google OAuth — Chrome extension identity API
# Create at: Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client ID (Chrome App type)
# The client ID must match the extension's public key / ID in the Chrome Web Store.
VITE_GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com

# BrightData (enrichment proxy — server-side only, never exposed to the extension)
BRIGHTDATA_API_KEY=your-brightdata-api-key-here

# Neon Serverless Postgres (Phase 2: Edge Functions point DB here)
# Get these from the Neon dashboard after creating a project.
# NEON_DATABASE_URL=postgres://user:pass@ep-xxx.region.neon.tech/dbname?sslmode=require
